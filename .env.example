# Copy to .env and fill in your values
APP_PASSWORD=your-secret-password

# Used automatically by docker-compose as NUXT_APP_PASSWORD
# For local dev (pnpm dev), this same var is read from .env / .env.local
REDIS_URL=redis://localhost:6379

# Docker Compose port override (optional)
# PORT=3000

# Set to false if you access the app over plain HTTP (e.g. homelab IP:3000)
# COOKIE_SECURE=false
